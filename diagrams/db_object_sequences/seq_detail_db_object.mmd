sequenceDiagram
    autonumber
    actor Client
    participant DOM as DatabaseObjectManager
    participant DBM as DatabaseManager
    participant SM as SchemaManager
    participant DTM as DataTypeManager
    participant TM as TableManager
    participant CM as ColumnManager
    participant VM as ViewManager
    participant SPM as StoredProcedureManager
    participant TRM as TriggerManager
    participant CSM as ConstraintManager
    participant RM as RelationshipManager
    participant IM as IndexManager
    participant MM as MetadataManager
    participant SC as SystemCatalog
    participant DM as DependencyManager
    participant STM as StatisticsManager

    rect rgb(238, 246, 255)
        Note over Client,MM: Database and schema provisioning
        Client->>DOM: provision_database(name, config)
        DOM->>DBM: create_database(name, config)
        DBM-->>DOM: Database with DatabaseDescriptor
        DOM->>MM: register("database", name, descriptor)
        MM->>SC: add("database:name", descriptor)
        DOM-->>Client: Database

        Client->>DOM: provision_schema(database, schema, version)
        DOM->>SM: create_schema(database, schema, version)
        SM-->>DOM: Schema with SchemaDescriptor
        DOM->>MM: register("schema", schema, descriptor, [database dependency])
        MM->>SC: add("schema:name", descriptor)
        MM->>DM: register_dependency(schema, database)
        DOM-->>Client: Schema
    end

    rect rgb(242, 255, 242)
        Note over Client,STM: Table definition
        Client->>DOM: provision_table(schema, name, table_schema)
        loop Each column
            DOM->>DTM: resolve(column.data_type)
            DTM-->>DOM: DataType
        end
        DOM->>TM: create_table(schema, name, table_schema, organization, scope)
        TM-->>DOM: Table with TableDescriptor
        loop Each ColumnDescriptor
            DOM->>CM: add_column(table_name, Column)
        end
        DOM->>MM: register("table", name, descriptor, [schema dependency])
        MM->>SC: add("table:name", descriptor)
        MM->>DM: register_dependency(table, schema)
        DOM->>STM: update_statistics(table, "row_count", 0)
        DOM-->>Client: Table
    end

    rect rgb(255, 248, 235)
        Note over Client,DM: Advanced objects
        opt Create view
            Client->>DOM: provision_view(schema, name, query, dependencies)
            DOM->>VM: create_view(schema, name, query, dependencies)
            DOM->>MM: register("view", name, descriptor, dependencies)
            MM->>SC: add(object_id, descriptor)
            MM->>DM: register_dependency(view, each target)
            DOM-->>Client: View
        end
        opt Create procedure
            Client->>DOM: provision_procedure(schema, name, parameters, body, dependencies)
            DOM->>SPM: create_procedure(schema, name, parameters, body)
            DOM->>MM: register("procedure", name, descriptor, dependencies)
            MM->>SC: add(object_id, descriptor)
            DOM-->>Client: StoredProcedure
        end
        opt Create trigger
            Client->>DOM: provision_trigger(table, name, event, timing, action, dependencies)
            DOM->>TRM: create_trigger(table, name, event, timing, action)
            DOM->>MM: register("trigger", name, descriptor, dependencies)
            MM->>SC: add(object_id, descriptor)
            DOM-->>Client: Trigger
        end
    end

    rect rgb(255, 240, 245)
        Note over Client,STM: INSERT / UPDATE / DELETE pipeline
        Client->>DOM: insert_row / update_row / delete_row
        DOM->>TRM: publish_table_event(table, operation, BEFORE, context)
        DOM->>DTM: convert_value() and validate_value()
        DOM->>CSM: validate_row(table, row, existing_rows)
        DOM->>RM: validate_row(table, row, table_manager)
        DOM->>IM: maintain_table_indexes(table, row, row_id, operation)
        DOM->>TM: Apply copy-on-write row mutation
        DOM->>TRM: publish_table_event(table, operation, AFTER, context)
        alt Any step fails
            DOM->>TM: Restore previous row state
            DOM->>IM: Restore previous index state
            DOM-->>Client: Raise error
        else Success
            DOM->>STM: update_statistics(table, "row_count", count)
            DOM->>MM: record_table_change(table, operation)
            DOM-->>Client: row_id / row
        end
    end

    rect rgb(245, 245, 245)
        Note over Client,TM: Query in-memory rows
        Client->>DOM: select_rows(table_ref, predicate)
        DOM->>TM: find_table(table_ref)
        DOM->>TM: select_rows(table, predicate)
        TM-->>DOM: tuple of rows
        DOM-->>Client: tuple of rows
    end
