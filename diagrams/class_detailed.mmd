    }

    class Database {
	    +name: str
    }

    class Schema {
	    +name: str
    }

    class Table {
	    +name: str
    }

    class View {
	    +name: str
	    +query: str
    }

    class Relationship {
	    +name: str
	    +source_table: str
	    +target_table: str
	    +relationship_type: str
    }

    class Column {
	    +name: str
	    +nullable: bool
	    +default_value: str
    }

    class Constraint {
	    +name: str
	    +constraint_type: str
	    +rule: str
    }

    class DataType {
	    +name: str
    }

    class Index {
	    +name: str
	    +index_type: str
