	    +create_view(name: str, query: str)
	    +drop_view(name: str)
	    +get_view(name: str)
    }

    class RelationshipManager {
	    +create_relationship(rel: Relationship)
	    +drop_relationship(name: str)
	    +validate_relationship(rel: Relationship)
    }

    class ColumnManager {
	    +add_column(table_name: str, column: Column)
